                  </Text>
                )}

                <Text style={styles.inputLabel}>😀 全体的な体調</Text>
                <OptionGroup
                  options={["良い", "普通", "不良"]}
                  selected={condition}
                  onSelect={setCondition}
                  color="#2ecc71"
                />
                <Text style={styles.inputLabel}>
