                <TouchableOpacity
                  style={styles.sendButton}
                  onPress={handleSendComment}
                >
                  <Text style={styles.sendButtonText}>送信</Text>
                </TouchableOpacity>
              </View>
            </View>
          </KeyboardAvoidingView>
        </SafeAreaView>
