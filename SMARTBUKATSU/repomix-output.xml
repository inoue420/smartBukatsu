                      style={[
                        styles.toggleBtnItem,
                        hasPain && { backgroundColor: "#e74c3c" },
                      ]}
                      onPress={() => setHasPain(true)}
                    >
                      <Text
                        style={[
                          styles.toggleText,
                          hasPain && { color: "#fff" },
                        ]}
                      >
                        あり
                      </Text>
                    </TouchableOpacity>
                  </View>
                </View>

                {hasPain ? (
                  <View style={styles.painDetailSection}>
