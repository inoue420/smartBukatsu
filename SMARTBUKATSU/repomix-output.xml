export async function getTeamInviteCode(teamId) {
  if (!teamId) return null;
  try {
    const teamSnap = await getDoc(doc(db, "teams", teamId));
    return teamSnap.exists() && teamSnap.data().inviteCode
      ? teamSnap.data().inviteCode
      : "未発行";
