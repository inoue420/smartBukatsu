                    {renderStars(achievement, setAchievement)}
                    <Text style={styles.ratingText}>{achievement} / 5</Text>
                  </View>

                  <Text style={[styles.inputLabel, { color: "#27ae60" }]}>
                    ✨ 良かった点
                  </Text>
