                                  </Text>
                                  <Text style={styles.painDetailText}>
                                    部位：{selectedReport.painDetails.part}{" "}
                                    (痛さ: {selectedReport.painDetails.level}
                                    /10)
                                  </Text>
                                  <Text style={styles.painDetailText}>
