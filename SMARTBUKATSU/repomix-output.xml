          displayDates.map((date, index) => {
            const reportsInDate = groupedReports[date] || [];
            const expanded = isExpanded(date, index);
            const hasUnreviewed = reportsInDate.some((d) => !d.isReviewed);

            // リストに表示するメンバーの決定（管理者向け）
