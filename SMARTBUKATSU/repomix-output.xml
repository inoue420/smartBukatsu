                </Text>
                <Text
                  style={{
                    color: "#555",
                    backgroundColor: "#f0f0f0",
                    padding: 10,
                    borderRadius: 5,
                    marginBottom: 10,
                  }}
                >
                  {ri.item.content}
                </Text>
                <View
                  style={{ flexDirection: "row", justifyContent: "flex-end" }}
                >
                  <TouchableOpacity
                    style={[
                      styles.dashBtn,
                      { backgroundColor: "#5cb85c", marginRight: 10 },
                    ]}
                    onPress={() =>
                      handleResolveReport(
                        ri.type,
                        ri.postId,
                        ri.replyId,
                        "ignore",
                      )
                    }
                  >
                    <Text style={{ color: "#fff" }}>✅ 問題なし</Text>
                  </TouchableOpacity>
                  <TouchableOpacity
                    style={[styles.dashBtn, { backgroundColor: "#d9534f" }]}
                    onPress={() =>
                      handleResolveReport(
                        ri.type,
                        ri.postId,
                        ri.replyId,
                        "delete",
                      )
                    }
                  >
                    <Text style={{ color: "#fff" }}>🗑 削除</Text>
                  </TouchableOpacity>
                </View>
              </View>
            ))}
          </ScrollView>
        </SafeAreaView>
      </Modal>
    </SafeAreaView>
  );
};

