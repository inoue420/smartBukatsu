                  )}
                </TouchableOpacity>

                {expanded &&
                  (isStaffOrAbove ? (
                    // ★ 管理者向け：1行のコンパクトなリスト表示
                    <View style={styles.memberList}>
                      {membersToRender.map((memberName) => {
                        const report = reportsInDate.find(
                          (r) => r.author === memberName,
